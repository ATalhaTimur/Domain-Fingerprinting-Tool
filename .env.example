# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional collectors ───────────────────────────────────────────────────────

# urlscan.io API key — free tier at https://urlscan.io/user/signup
# Without this key urlscan collector returns {"urlscan_error": "..."} and scan continues
URLSCAN_API_KEY=

# ── Cache (dev default = SQLite, no config needed) ────────────────────────────

# Set to "production" to switch cache backend from SQLite → Redis
# and to hide stack traces in error responses
APP_ENV=development

# Redis connection URL — only used when APP_ENV=production
REDIS_URL=redis://localhost:6379
